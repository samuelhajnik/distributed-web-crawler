POSTGRES_USER=crawler
POSTGRES_PASSWORD=crawler
POSTGRES_DB=crawler
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
REDIS_HOST=redis
REDIS_PORT=6379
CONTROL_PLANE_PORT=3000
WORKER_CONCURRENCY=8
MAX_RETRIES=2
# Demo-friendly: reclaim stale IN_PROGRESS rows quickly (seconds).
CLAIM_STALE_SECONDS=10
# HTTP fetch deadline per URL when env overrides default (milliseconds).
CRAWL_REQUEST_TIMEOUT_MS=5000
RECONCILE_INTERVAL_SECONDS=10
RECONCILE_BATCH_SIZE=500
RETRY_BASE_DELAY_MS=1000
RETRY_MAX_DELAY_MS=30000
RETRY_429_MULTIPLIER=4
WORKER_ID=
WORKER_METRICS_PORT=9091
FETCH_CONCURRENCY=12
FETCH_CONCURRENCY_PER_HOST=4
